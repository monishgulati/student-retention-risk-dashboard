{
    "version": 2,
    "buildCommand": "cd student_Dashboard && npm install && npm run build",
    "outputDirectory": "student_Dashboard/dist",
    "rewrites": [
        {
            "source": "/api/feature-importance",
            "destination": "/api/feature_importance"
        },
        {
            "source": "/((?!api).*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/api/(.*)",
            "headers": [
                {
                    "key": "Access-Control-Allow-Credentials",
                    "value": "true"
                },
                {
                    "key": "Access-Control-Allow-Origin",
                    "value": "*"
                },
                {
                    "key": "Access-Control-Allow-Methods",
                    "value": "GET,POST,OPTIONS"
                },
                {
                    "key": "Access-Control-Allow-Headers",
                    "value": "Content-Type"
                }
            ]
        }
    ]
}
